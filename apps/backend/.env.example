# ─── InstantDB ────────────────────────────────────────────────────────────────
INSTANT_APP_ID=
INSTANT_ADMIN_TOKEN=

# ─── Redis (BullMQ) ───────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── Soft Seguros API ─────────────────────────────────────────────────────────
SOFT_SEGUROS_API_URL=https://app.softseguros.com
SOFT_SEGUROS_USERNAME=
SOFT_SEGUROS_PASSWORD=
SOFT_SEDE_ID=
SOFT_VENDEDOR_ID=

# ─── Qualitas (Cotizador Autos) ───────────────────────────────────────────────
QUALITAS_URL=https://serviciosqa.qualitascolombia.com.co/Emision_QA/api/Emision
QUALITAS_USER=
QUALITAS_PASSWORD=
QUALITAS_NO_NEGOCIO=
QUALITAS_AGENTE=

# ─── Allianz (Cotizador Autos) ────────────────────────────────────────────────
ALLIANZ_URL=https://secure-eu-uat-colombia.apis.allianz.com/drswoc16/services/AutosIndividualWS
ALLIANZ_PARTNER_ID=
ALLIANZ_AGENT_ID=
ALLIANZ_PARTNER_CODE=
ALLIANZ_AGENT_CODE=
ALLIANZ_CERT_PATH=./certs/your-certificate.pfx
ALLIANZ_CERT_PASSWORD=
# Alternativa para Render (sin acceso al filesystem): base64 del .pfx
# Generar con: base64 -w0 cert.pfx  (Linux/Mac) o certutil -encode cert.pfx cert.b64 (Windows)
ALLIANZ_CERT_BASE64=

# ─── SBS (Cotizador Autos) ────────────────────────────────────────────────────
SBS_URL=https://test.cotizadoresgenerales.com/wsCotizaAutos/CotizaAutos.asmx
SBS_USER=
SBS_PASSWORD=
# Valor de CodFactComision — solicitado a Ivan David Diaz (SBS) el 6 May 2026
SBS_COD_FACT_COMISION=

# ─── Google OAuth2 ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3002/api/auth/google/callback

# ─── App ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
PORT=3002

# ─── Renovaciones Job ─────────────────────────────────────────────────────────
# IMPORT_CRON="0 7 * * *"
