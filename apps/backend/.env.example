# ─── InstantDB ────────────────────────────────────────────────────────────────
INSTANT_APP_ID=
INSTANT_ADMIN_TOKEN=

# ─── Redis (BullMQ) ───────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── Soft Seguros API ─────────────────────────────────────────────────────────
